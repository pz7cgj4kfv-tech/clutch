{ "version":"0.0.1","configurations":[{ "name":"saw6dbg","runtimeExecutable":"node","runtimeArgs":["-e","const http=require('http'),fs=require('fs'),path=require('path');const root='/Users/saugydavid/Documents/masteraudit/app';http.createServer((q,s)=>{let p=path.join(root,decodeURIComponent(q.url.split('?')[0]));try{if(fs.statSync(p).isDirectory())p=path.join(p,'index.html');}catch(e){}fs.readFile(p,(e,d)=>{if(e){s.writeHead(404);s.end('nf');}else{s.writeHead(200,{'Content-Type':p.endsWith('.html')?'text/html; charset=utf-8':'application/octet-stream'});s.end(d);}});}).listen(8791,()=>console.log('up'));"],"port":8791 }]}
