{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "masteraudit-preview",
      "runtimeExecutable": "node",
      "runtimeArgs": ["-e", "const http=require('http'),fs=require('fs'),pa=require('path');const dir='/Users/saugydavid/Documents/masteraudit/app';http.createServer((q,r)=>{let u=q.url.split('?')[0];let f=pa.join(dir,u==='/'?'index.html':u);fs.readFile(f,(e,d)=>{if(e){r.writeHead(404);r.end('nf');}else{r.setHeader('Content-Type',f.endsWith('.html')?'text/html':'application/octet-stream');r.end(d);}});}).listen(4611,()=>console.log('up 4611'));"],
      "port": 4611
    }
  ]
}
